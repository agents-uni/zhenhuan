{
  "name": "@agents-uni/zhenhuan",
  "version": "0.1.4",
  "description": "Zhen Huan palace drama themed agent competition system built on @agents-uni/core",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "zhenhuan": "dist/cli/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src/agents/souls/",
    "universe.yaml",
    "README.md",
    "README.en.md",
    "DESIGN.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "dev": "tsx --watch src/cli/index.ts serve",
    "start": "tsx src/cli/index.ts serve",
    "serve": "tsx src/cli/index.ts serve",
    "zhenhuan": "tsx src/cli/index.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "agents",
    "multi-agent",
    "competition",
    "elo",
    "horse-race",
    "openclaw",
    "ai-agents"
  ],
  "author": "agents-uni",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agents-uni/zhenhuan.git"
  },
  "homepage": "https://github.com/agents-uni/zhenhuan#readme",
  "bugs": {
    "url": "https://github.com/agents-uni/zhenhuan/issues"
  },
  "dependencies": {
    "@agents-uni/core": "^0.3.0",
    "@hono/node-server": "^1.13.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "hono": "^4.6.0"
  },
  "optionalDependencies": {
    "@agents-uni/unis": "^0.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
